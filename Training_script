def get_latest_checkpoint(save_dir):
    os.makedirs(save_dir, exist_ok=True)
    checkpoint_files = os.listdir(save_dir)
    print(f"🔎 Files in {save_dir}: {checkpoint_files}")  # DEBUG

    checkpoint_files = [f for f in checkpoint_files if f.endswith('.pt')]
    print(f"🧹 PT files: {checkpoint_files}")  # DEBUG

    # ✅ Match "checkpoint_epoch_<number>.pt"
    checkpoint_files = [f for f in checkpoint_files if re.match(r'checkpoint_epoch_\d+\.pt', f)]
    print(f"✅ Matching checkpoints: {checkpoint_files}")  # DEBUG

    if not checkpoint_files:
        return None

    checkpoint_files.sort(key=lambda x: int(x.split('_')[-1].split('.')[0]))  # still good
    return os.path.join(save_dir, checkpoint_files[-1])

def validate(model, batch_size, device, world_size, rank, num_workers):  
    model.eval()
    criterion = BCEWithLogitsLoss()
    val_loss_metric = MeanMetric(sync_on_compute=True).to(device)
    val_acc_metric = Accuracy(task="binary", sync_on_compute=True).to(device)


    # Build val dataset and sampler using provided rank and num_workers
    val_dataset = IterableChunkDataset(
    input_ids_path=f"./tokenized_val_npy/input_ids_val.npy", 
    attention_mask_path=f"./tokenized_val_npy/attention_mask_val.npy", 
    labels_path=f"./tokenized_val_npy/labels_val.npy"
    shuffle=False,
    rank=rank,
    world_size=world_size
)
    val_dataloader = DataLoader(val_dataset, batch_size=batch_size,
                                num_workers=num_workers, persistent_workers=False,
                                worker_init_fn=worker_init_fn)

    with torch.no_grad():
        val_loss_metric.reset()
        val_acc_metric.reset()

        for batch in val_dataloader:
            input_ids = batch['input_ids'].to(device)
            attention_mask = batch['attention_mask'].to(device)

            labels = batch['labels'].float().to(device).view(-1)

            logits = model(input_ids=input_ids, attention_mask=attention_mask).view(-1)
            loss = criterion(logits, labels)

            probs = torch.sigmoid(logits)
            val_loss_metric.update(loss.detach())
            val_acc_metric.update(probs, labels)


        # cleanup
        del val_dataloader, val_dataset
        torch.cuda.empty_cache()
        gc.collect()
    
    return val_loss_metric.compute().item(), val_acc_metric.compute().item()

    
